# ===== Application Configuration =====
APP_NAME=Message Sync Gateway
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===== Feishu Configuration =====
# 飞书应用配置
FEISHU_ENABLED=false
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# ===== Telegram Configuration =====
# Telegram Bot 配置
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ===== Fanfou Configuration =====
# 饭否 API 配置
FANFOU_ENABLED=false
FANFOU_CONSUMER_KEY=your_consumer_key_here
FANFOU_CONSUMER_SECRET=your_consumer_secret_here
FANFOU_ACCESS_TOKEN=your_access_token_here
FANFOU_ACCESS_SECRET=your_access_secret_here

# ===== Database Configuration =====
# SQLite 数据库配置
DATABASE_ENABLED=true
DATABASE_PATH=./data/messages.db

# ===== Logging Configuration =====
# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ===== Usage Instructions =====
# 1. 复制此文件为 .env
# 2. 根据需要启用相应的平台（设置 ENABLED=true）
# 3. 填写对应平台的认证信息
# 4. 运行：uv run python -m app.main
