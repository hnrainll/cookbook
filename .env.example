# ===== Application Configuration =====
APP_NAME=Message Sync Gateway
DEBUG=false
HOST=0.0.0.0
PORT=8009

# ===== Feishu Configuration =====
# 飞书应用配置
FEISHU_ENABLED=false
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# ===== Telegram Configuration =====
# Telegram Bot 配置
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
# 频道/群组 ID，支持 @username 或数字 ID（如 -1001234567890），留空则不启用频道同步
TELEGRAM_CHANNEL_ID=
# 代理地址（国内访问 Telegram API 需要），留空则直连
TELEGRAM_PROXY=

# ===== Fanfou Configuration =====
# 饭否 API 配置
FANFOU_ENABLED=false
FANFOU_CONSUMER_KEY=your_consumer_key_here
FANFOU_CONSUMER_SECRET=your_consumer_secret_here
FANFOU_OAUTH_CALLBACK=http://127.0.0.1:8009/auth?platform=fanfou

# ===== Mastodon Configuration =====
# Mastodon Access Token 配置
MASTODON_ENABLED=false
MASTODON_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=your_access_token_here
MASTODON_VISIBILITY=public

# ===== Threads Configuration =====
# Threads OAuth 2.0 配置
THREADS_ENABLED=false
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here
THREADS_REDIRECT_URI=http://127.0.0.1:8009/auth?platform=threads
THREADS_BASE_URL=https://graph.threads.net
THREADS_REFRESH_WINDOW_DAYS=7

# ===== Database Configuration =====
# SQLite 数据库配置
DATABASE_ENABLED=true
DATABASE_PATH=./data/messages.db

# ===== Logging Configuration =====
# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ===== Usage Instructions =====
# 1. 复制此文件为 .env
# 2. 根据需要启用相应的平台（设置 ENABLED=true）
# 3. 填写对应平台的认证信息
# 4. 运行：uv run uvicorn app.main:app --host 0.0.0.0 --port 8009 --reload
